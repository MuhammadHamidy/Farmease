    {
      "name": "Perkawinan",
      "item": [
        {
          "name": "Cek Inbreeding (Pre-validation)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id_domba_jantan\": 2,\n  \"id_domba_betina\": 7\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/perkawinan/cek-inbreeding",
              "host": ["{{base_url}}"],
              "path": ["api", "perkawinan", "cek-inbreeding"]
            },
            "description": "Cek risiko inbreeding sebelum perkawinan dicatat. Menggunakan metode Wright (CoI), traversal 5 generasi. Endpoint ini hanya cek — tidak menyimpan data."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"id_jantan\": 2,\n  \"id_betina\": 7,\n  \"coefficient_of_inbreeding\": 0.125,\n  \"persen_kekerabatan\": 12.5,\n  \"flag_sedarah\": true,\n  \"level_risiko\": \"sedang\",\n  \"leluhur_bersama\": [\n    { \"id_domba\": 1, \"nama_domba\": \"Induk Asli\", \"jalur\": [\"jantan>bapak\", \"betina>ibu\"] }\n  ],\n  \"rekomendasi\": \"Perkawinan berisiko. Pertimbangkan pasangan lain untuk mengurangi inbreeding depression.\"\n}"
            }
          ]
        },
        {
          "name": "Get Daftar Perkawinan",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/perkawinan?status=selesai&flag_sedarah=false&page=1",
              "host": ["{{base_url}}"],
              "path": ["api", "perkawinan"],
              "query": [
                { "key": "id_domba", "value": "", "description": "Filter by domba jantan/betina (opsional)", "disabled": true },
                { "key": "status", "value": "selesai", "description": "proses/selesai/gagal (opsional)" },
                { "key": "flag_sedarah", "value": "false", "description": "true/false (opsional)" },
                { "key": "tanggal_dari", "value": "", "description": "Format YYYY-MM-DD (opsional)", "disabled": true },
                { "key": "tanggal_sampai", "value": "", "description": "Format YYYY-MM-DD (opsional)", "disabled": true },
                { "key": "page", "value": "1" }
              ]
            },
            "description": "Daftar perkawinan dengan filter"
          },
          "response": [
