{
  "info": {
    "name": "API Sistem Peternakan Domba",
    "description": "Postman Collection untuk API Sistem Peternakan Domba v1.0. RESTful JSON API dengan JWT Bearer Auth.\n\nBase URL: https://api.peternakan.app/v1\n\nUntuk menggunakan collection ini:\n1. Set variable `base_url` = https://api.peternakan.app/v1\n2. Login via POST /api/auth/login\n3. Copy token ke variable `token`",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "peternakan-domba-v1"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://api.peternakan.app/v1",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string",
      "description": "JWT Bearer Token dari response login"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin01\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Login & mendapatkan JWT token. Simpan token ke variable `token`."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.token) {",
                  "  pm.collectionVariables.set('token', json.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"token\": \"eyJ...\",\n  \"expires_at\": \"2024-12-01T10:00:00Z\",\n  \"akun\": {\n    \"id_akun\": 1,\n    \"username\": \"admin01\",\n    \"kategori_operator\": \"admin\",\n    \"role\": { \"id_role\": 1, \"nama_role\": \"Admin\", \"hak_akses\": \"full\" }\n  }\n}"
            }
          ]
        }
      ]
    },
