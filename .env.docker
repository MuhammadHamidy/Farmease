# Database — selaras Farmease-BE/farmease/config/config.json (user/pass, farmease_be, port 5435)
DB_USER=user
DB_PASSWORD=pass
DB_NAME=farmease_be
DB_PORT=5435

# Redis — selaras config.json (localhost:6381 saat diakses dari host)
REDIS_PORT=6381

# Backend
APP_ENV=development
BACKEND_PORT=8080
JWT_SECRET=farmease-secret-key-123

# Frontend (URL yang dipanggil browser, bukan nama container)
FRONTEND_PORT=3000
VITE_API_BASE_URL=http://localhost:8080
